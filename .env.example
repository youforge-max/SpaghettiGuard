# --- Spaghetti Detector config ---
# NOTE: systemd EnvironmentFile does NOT strip inline comments — keep values on
# their own line with no trailing "# ...". (Comments on their own line are fine.)

# Printer webcam snapshot (mjpg-streamer) — set to your printer's IP
SNAPSHOT_URL=http://192.0.2.72/webcam/?action=snapshot

# Obico ml_api endpoint (local container, does the inference)
ML_API_URL=http://127.0.0.1:3333
# ML_API_TOKEN only if you set one on the container; blank = ml_api auth disabled
ML_API_TOKEN=

# Web UI bind
HOST=0.0.0.0
PORT=8110

# Detection / debounce
CONF=0.25
POLL_SEC=6
ALERT_STREAK=3
CLEAR_STREAK=5

# --- Actions on ALERT ---
# Pause the print via Moonraker when a failure is confirmed. Default ON.
# This only sets the STARTING value — you can flip it live from the dashboard
# or via POST /api/auto_pause. Set to 0 to start in notify-only mode.
AUTO_PAUSE=1
MOONRAKER_URL=http://192.0.2.72:7125

# Email alert (optional; reuses SOC gmail SMTP pattern). Blank = disabled.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
